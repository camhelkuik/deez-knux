<div class="knux-actions">
<div class="d-flex flex-row align-items-center justify-content-around">
    <button type="button" class="btn primary-button btn-lg mb-3" {{on "click" this.generateKnux}}>Deez Knux!</button>
</div>

<div class="d-flex flex-row align-items-center justify-content-center">
    <label class="btn secondary-actions active mr-1">
        <input type="checkbox" {{on "click" this.toggleCaps}}> Show knux as all caps
    </label>

    <BsDropdown class="mb-2 ml-1" as |dd|>
        <dd.button class="secondary-actions">Select Font <span class="caret"></span></dd.button>
        <dd.menu as |ddm|>
            <ddm.item>
                <button class="dropdown-item" style="font-family:default"
                    {{action "changeFont" "Default"}}>Default</button>
            </ddm.item>
            <ddm.item>
                <button class="dropdown-item" style="font-family:Walter Turncoat"
                    {{action "changeFont" "Walter Turncoat"}}>Walter Turncoat</button>
            </ddm.item>
            <ddm.item>
                <button class="dropdown-item" style="font-family:Bebas Neue" {{action "changeFont" "Bebas Neue"}}>Bebas
                    Neue</button>
            </ddm.item>
            <ddm.item>
                <button class="dropdown-item" style="font-family:Ewert" {{action "changeFont" "Ewert"}}>Ewert</button>
            </ddm.item>
            <ddm.item>
                <button class="dropdown-item" style="font-family:Sancreek"
                    {{action "changeFont" "Sancreek"}}>Sancreek</button>
            </ddm.item>
            <ddm.item>
                <button class="dropdown-item" style="font-family:IM Fell Double Pica"
                    {{action "changeFont" "IM Fell Double Pica"}}>IM Fell Double Pica</button>
            </ddm.item>
            <ddm.item>
                <button class="dropdown-item" style="font-family:Quando"
                    {{action "changeFont" "Quando"}}>Quando</button>
            </ddm.item>
        </dd.menu>
    </BsDropdown>

</div>

<div class="d-flex flex-row align-items-center justify-content-center mb-3">
    <div class="mr-5">
        <h3>Font Color Picker</h3>
        <div class="d-flex flex-row align-items-center justify-content-center">
            {{spectrum-color-picker
            preferredFormat="hex"
            color=knuxFontColor
            onChange=(action "fontColorChanged")
            }}
        </div>

    </div>

    <div>
        <h3>Knux Color Picker</h3>
        <div class="d-flex flex-row align-items-center justify-content-center">
            {{spectrum-color-picker
            preferredFormat="hex"
            color=knuxColor
            onChange=(action "knuxColorChanged")
            }}
        </div>
    </div>

</div>
</div>
<div class="">
  <img class="knux-image" style="background:{{this.knuxColor}}" src="/assets/images/full-knux.png"
        alt="drawing of two fists">
</div>


  <div class="all-knux">

    <div class="knuxR1" style="color:{{this.knuxFontColor}}; font-family:{{this.knuxFont}};"> {{this.knuxR1}}
    </div>
    <div class="knuxR2" style="color:{{this.knuxFontColor}}; font-family:{{this.knuxFont}};"> {{this.knuxR2}}
    </div>
    <div class="knuxR3" style="color:{{this.knuxFontColor}}; font-family:{{this.knuxFont}};"> {{this.knuxR3}}
    </div>
    <div class="knuxR4" style="color:{{this.knuxFontColor}}; font-family:{{this.knuxFont}};"> {{this.knuxR4}}
    </div>
     <div class="knuxL1" style="color:{{this.knuxFontColor}}; font-family:{{this.knuxFont}};"> {{this.knuxL1}}
    </div>
    <div class="knuxL2" style="color:{{this.knuxFontColor}}; font-family:{{this.knuxFont}};"> {{this.knuxL2}}
    </div>
    <div class="knuxL3" style="color:{{this.knuxFontColor}}; font-family:{{this.knuxFont}};"> {{this.knuxL3}}
    </div>
    <div class="knuxL4" style="color:{{this.knuxFontColor}}; font-family:{{this.knuxFont}};"> {{this.knuxL4}}
    </div>

</div>

